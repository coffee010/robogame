# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/

# Build and packaging output
build/
dist/
*.egg-info/

# Local configuration and secrets
.env
.env.*
*.local

# Logs and temporary files
*.log
*.tmp
tmp/
temp/
.cache/

# Editor and OS files
.idea/
.vscode/
.DS_Store
Thumbs.db

# Robot model binaries and generated assets.
# Keep small metadata files in Git, but store large/versioned model files elsewhere.
assets/models/*
!assets/models/.gitkeep
!assets/models/README.md
!assets/models/manifest*.json
!assets/models/piper/
!assets/models/piper/.gitkeep
*.onnx
*.onnx.json
*.pt
*.pth
*.tflite
*.task
!assets/models/gesture_recognizer.task
*.pkl
*.joblib

# Captured runtime media can get large quickly
captures/
recordings/
*.mp4
*.avi
*.mov
*.wav
# Curated voice lines are required at runtime and small enough to keep in Git.
!assets/sounds/*.wav
# Expression clips are part of the demo and small enough to keep in Git.
!assets/expressions/**/*.mp4
!assets/expressions/**/*.mov
!assets/expressions/**/*.avi

# Piper downloads Chinese phonemizer resources here when --data-dir is not set.
g2pW/
